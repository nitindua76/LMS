# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=lms
POSTGRES_PASSWORD=lmspassword
POSTGRES_DB=lms

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-me-in-production-generate-with-secrets-token-hex-64
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Cookies ───────────────────────────────────────────────────────────────────
# Set COOKIE_SECURE=true and COOKIE_SAMESITE=strict in production (HTTPS)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Rate limiting: max failed login attempts before lockout
LOGIN_MAX_ATTEMPTS_PER_IP=20
LOGIN_WINDOW_SECONDS=300
ACCOUNT_MAX_ATTEMPTS=10
ACCOUNT_LOCKOUT_SECONDS=900

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
