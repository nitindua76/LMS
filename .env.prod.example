# Production environment — copy to .env.prod on the VM and fill in real
# values. NEVER commit .env.prod (it's in .gitignore already).

# ── Networking (internal-only deployment, no public DNS) ────────────────────
# The hostname employees will browse to — must resolve to the VM's IP via
# internal DNS or a hosts-file entry on each machine. Also used by Caddy to
# issue its internal TLS cert (see Caddyfile) and by LiveKit's node_ip.
INTERNAL_HOSTNAME=lms.internal
# The VM's actual LAN IP (not 127.0.0.1) — other employees' machines need to
# reach LiveKit's media ports here directly for video/audio to connect.
LIVEKIT_NODE_IP=10.0.0.50
LIVEKIT_RTC_PORT_RANGE_START=55000
LIVEKIT_RTC_PORT_RANGE_END=55100

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=lms
POSTGRES_PASSWORD=change-me-generate-a-real-password
POSTGRES_DB=lms

# ── Redis / MinIO ─────────────────────────────────────────────────────────────
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me-generate-a-real-password

# ── JWT / cookies ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-me-generate-with-secrets-token-hex-64
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── SCORM session tokens ──────────────────────────────────────────────────────
SCORM_TOKEN_SECRET=change-me-generate-with-secrets-token-hex-32

# ── LiveKit ───────────────────────────────────────────────────────────────────
LIVEKIT_API_KEY=change-me
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
LIVEKIT_API_SECRET=change-me-generate-with-secrets-token-hex-32

# ── SMTP (real internal mail relay — there's no Mailpit in production) ──────
SMTP_HOST=mail.yourcompany.internal
SMTP_PORT=25
SMTP_FROM=lms@yourcompany.com

# ── Container registry / image tag (used by docker-compose.prod.yml) ────────
REGISTRY=ghcr.io
GITHUB_REPOSITORY=your-org/lms
IMAGE_TAG=latest
