# Multi-stage: build the static bundle, then serve it with nginx — dev's
# Dockerfile runs `vite dev` (hot-reload, unoptimized, dev-only), which is
# never appropriate to run in production.
FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
